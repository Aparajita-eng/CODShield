# Backend environment variables
# Copy this file to .env and fill in your values — never commit .env to git

# ── Database (PostgreSQL via Prisma) ──────────────────────────────────────
# Pooled connection URL (used by Prisma Client at runtime)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/codshield

# Direct connection URL (used by Prisma Migrate — bypasses connection pooler)
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/codshield

# ── Server ─────────────────────────────────────────────────────────────────
PORT=5001

# ── SMS Gateway (pick one, leave the other blank) ─────────────────────────

# Option A: 2Factor.in (recommended for India)
# Get your key at https://2factor.in
TWOFACTOR_API_KEY=

# Option B: Twilio
# Get credentials at https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
