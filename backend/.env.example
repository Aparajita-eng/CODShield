# Backend environment variables
# Copy this file to .env and fill in your values — never commit .env to git

# ── Database (PostgreSQL via Prisma) ──────────────────────────────────────
# Pooled connection URL (used by Prisma Client at runtime)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/codshield

# Direct connection URL (used by Prisma Migrate — bypasses connection pooler)
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/codshield

# ── Server ─────────────────────────────────────────────────────────────────
PORT=5001

# ── Session / Auth ─────────────────────────────────────────────────────────
SESSION_SECRET=change-me-in-production

# Demo login fallback (works without database)
DEMO_USER_EMAIL=demo@codshield.com
DEMO_USER_PASSWORD=Demo@1234

# Demo-only: merchant UUID bound to the demo dashboard user (see demoData.ts)
# DEMO_MERCHANT_ID=a0000000-0000-4000-8000-000000000001

# Frontend URL — used for CORS (allowed browser origin) and password-reset links.
# Development default (Next.js on port 3000):
FRONTEND_URL=http://localhost:3000
# Production example (no trailing slash):
# FRONTEND_URL=https://codshield-web.onrender.com
# Multiple origins (comma-separated) are supported.

# Optional: Resend.com for password reset emails
RESEND_API_KEY=
RESET_EMAIL_FROM=CODShield <noreply@codshield.com>

# ── SMS Gateway (pick one, leave the other blank) ─────────────────────────

# Option A: 2Factor.in (recommended for India)
# Get your key at https://2factor.in
TWOFACTOR_API_KEY=

# Option B: Twilio
# Get credentials at https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
