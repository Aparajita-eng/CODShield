datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum IntegrationProvider {
  SHOPIFY
  WOOCOMMERCE
  MAGENTO
  CUSTOM_API
  DEMO
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  SYNCING
  ERROR
}

enum IntegrationSyncMode {
  PULL
  WEBHOOK
  MANUAL
  PUSH
}

enum PaymentMode {
  COD
  PREPAID
}

enum WorkflowStage {
  IMPORTED
  PINCODE
  TRUST_SCORE
  FRAUD_CHECK
  WHATSAPP
  AI_CALL
  DECISION
  COMPLETED
}

enum OverallStatus {
  IN_PROGRESS
  PROTECTED
  HELD
  FAILED
  CANCELLED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  MANUAL_REVIEW
}

enum JobStatus {
  QUEUED
  PROCESSING
  SUCCESS
  FAILED
}

enum RiskDecision {
  ALLOW_COD
  OTP_REQUIRED
  AI_CALL_REQUIRED
  PREPAID_ONLY
  BLOCK_ORDER
  MANUAL_REVIEW
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  companyName  String?
  phone        String?
  merchantId   String?
  merchant     Merchant? @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  role         String    @default("Owner")
  createdAt    DateTime  @default(now())

  @@index([merchantId])
}

model Merchant {
  id                  String               @id @default(uuid())
  name                String
  apiKeyHash          String               @unique
  apiKeyMask          String
  tier                String               // Starter, Growth, Enterprise
  claimRatio          Float                @default(0.0)
  orders              Order[]
  users               User[]
  createdAt           DateTime             @default(now())

  // New Integration Scoping
  integrations        Integration[]
  apiKeys             ApiKey[]
  serviceIntegrations ServiceIntegration[]
  settings            MerchantSettings?
  rules               Rule[]
  auditLogs           AuditLog[]
}

// Normalized Buyer
model Buyer {
  id                   String    @id @default(uuid())
  phone                String    @unique
  email                String?
  name                 String
  trustScore           Int       @default(100) // 0-100
  totalOrders          Int       @default(0)
  successfulDeliveries Int       @default(0)
  rtoCount             Int       @default(0)
  fraudCount           Int       @default(0)
  lastOrderDate        DateTime?
  deletedAt            DateTime?

  orders               Order[]
}

// Normalized & Extended Order
model Order {
  id                 String             @id @default(uuid())
  merchantId         String
  merchant           Merchant           @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  buyerId            String
  buyer              Buyer              @relation(fields: [buyerId], references: [id])
  value              Float
  paymentMode        PaymentMode        @default(COD)
  currentStage       WorkflowStage      @default(IMPORTED)
  overallStatus      OverallStatus      @default(IN_PROGRESS)
  verificationStatus VerificationStatus @default(PENDING)
  
  // Integration mapping fields
  externalOrderId    String             @default("")
  providerOrderId    String?
  provider           IntegrationProvider @default(DEMO)
  integrationId      String?
  integration        Integration?       @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  // Legacy compatibility fields (kept for existing service layer)
  phone              String?
  pincode            String?
  riskScore          Int?
  protectionStatus   String?
  fulfillmentStatus  String?
  statusReason       String?
  fraudFlagged       Boolean            @default(false)
  
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?

  // Relations
  claims             Claim[]
  events             OrderEvent[]
  riskAssessments    RiskAssessment[]
  verificationJobs   VerificationJob[]
  items              OrderItem[]
  shippingAddress    ShippingAddress?
  decisions          MerchantDecision[]
  notifications      NotificationLog[]
  recommendations    LogisticsRecommendation[]
  shipment           Shipment?
}

// Shipping Address Table
model ShippingAddress {
  id        String   @id @default(uuid())
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  line1     String
  line2     String?
  city      String
  state     String
  country   String   @default("IN")
  pincode   String
}

// Order Items
model OrderItem {
  id          String @id @default(uuid())
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sku         String?
  productName String
  quantity    Int
  price       Float
}

// Risk Assessment Table
model RiskAssessment {
  id            String       @id @default(uuid())
  orderId       String
  order         Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  buyerScore    Int
  pincodeScore  Int
  velocityScore Int
  deviceScore   Int
  fraudScore    Int
  decision      RiskDecision
  createdAt     DateTime     @default(now())
}

// Order events
model OrderEvent {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  eventName   String   // "Imported", "WhatsApp Sent", "OTP Verified", "AI Call Failed", etc.
  description String?
  createdAt   DateTime @default(now())
}

// Verification Job Queue
model VerificationJob {
  id          String    @id @default(uuid())
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type        String    // "WHATSAPP", "AI_CALL"
  status      JobStatus @default(QUEUED)
  retryCount  Int       @default(0)
  scheduledAt DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Webhook events logger
model WebhookEvent {
  id          String              @id @default(uuid())
  provider    IntegrationProvider
  payload     String              @db.Text
  signature   String?
  processed   Boolean             @default(false)
  receivedAt  DateTime            @default(now())
}

// Integration configurations
model Integration {
  id            String              @id @default(uuid())
  merchantId    String
  merchant      Merchant            @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  provider      IntegrationProvider
  status        IntegrationStatus   @default(DISCONNECTED)
  syncMode      IntegrationSyncMode
  apiKey        String?
  accessToken   String?
  refreshToken  String?
  storeUrl      String?
  webhookSecret String?
  lastSync      DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  deletedAt     DateTime?
  
  syncLogs      SyncLog[]
  orders        Order[]

  @@index([merchantId])
}

// Sync execution log tracking
model SyncLog {
  id            String      @id @default(uuid())
  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  startedAt     DateTime    @default(now())
  completedAt   DateTime?
  importedCount Int         @default(0)
  skippedCount  Int         @default(0)
  failedCount   Int         @default(0)
  status        String      // SUCCESS, FAILED
  durationMs    Int?
}

// Custom API key configs
model ApiKey {
  id          String    @id @default(uuid())
  merchantId  String
  merchant    Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  name        String
  keyHash     String    @unique
  keyMask     String
  prefix      String
  lastFour    String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?
}

// Merchant Decisions
model MerchantDecision {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  merchantId  String
  decision    String   // APPROVE, REJECT, HOLD, FORCE_DELIVER
  reason      String?
  createdAt   DateTime @default(now())
  createdBy   String?
}

// Notification log history
model NotificationLog {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type      String   // WHATSAPP, SMS, EMAIL, AICALL
  provider  String   // TWILIO, 2FACTOR, MAIL
  status    String   // SENT, DELIVERED, FAILED
  response  String?  @db.Text
  createdAt DateTime @default(now())
}

model PincodeRisk {
  pincode    String @id
  riskWeight Float  // 0.0 to 1.0
}

model Blacklist {
  phone        String   @id
  refusalCount Int
  reason       String
  createdAt    DateTime @default(now())
}

model Claim {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  proofUrl  String
  status    String   // Pending, Approved, Rejected
  step      Int      // 1: Upload, 2: Courier, 3: AI Check, 4: Payout
  notes     String?
  createdAt DateTime @default(now())
}

model VerifiedPhone {
  phone     String   @id
  expiresAt DateTime
}

model OtpAttempt {
  phone          String   @id
  attempts       Int      @default(0)
  firstAttemptAt DateTime @default(now())
}

model PasswordResetToken {
  tokenHash String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model DemoBooking {
  id            String        @id @default(uuid())
  name          String
  email         String
  company       String
  phone         String
  date          String        // YYYY-MM-DD
  timeSlot      String
  message       String?       @db.Text
  status        BookingStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

enum ServiceType {
  LOGISTICS
  WHATSAPP
  AI_VOICE
  SMS
  EMAIL
  PAYMENT
}

enum LogisticsProvider {
  SHIPROCKET
  DELHIVERY
  BLUEDART
  DTDC
  XPRESSBEES
  SHADOWFAX
  AMAZON_SHIPPING
  NIMBUSPOST
  CUSTOM
}

enum VerificationProvider {
  META
  TWILIO
  EXOTEL
  MERCHANT
  CODSHIELD
}

enum NotificationProvider {
  EMAIL
  SMS
  PUSH
  WHATSAPP
}

model ServiceIntegration {
  id              String               @id @default(uuid())
  merchantId      String
  merchant        Merchant             @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  type            ServiceType
  provider        String
  encryptedConfig String               @db.Text
  configVersion   Int                  @default(1)
  validatedAt     DateTime?
  lastHealthCheck DateTime?
  lastError       String?
  status          IntegrationStatus    @default(DISCONNECTED)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([merchantId])
}

model MerchantSettings {
  merchantId                  String    @id
  merchant                    Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  autoDispatch                Boolean   @default(false)
  enableCourierRecommendation Boolean   @default(true)
  enableAIConfirmation        Boolean   @default(true)
  defaultCourier              String?
  fallbackVerification        Boolean   @default(true)
  analyticsRealtime           Boolean   @default(true)
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
}

model Rule {
  id          String   @id @default(uuid())
  merchantId  String
  merchant    Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  priority    Int      @default(0)
  conditions  Json
  action      Json
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([merchantId])
}

model LogisticsRecommendation {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courier     String
  score       Float
  rank        Int
  reason      String
  createdAt   DateTime @default(now())

  @@index([orderId])
}

model AuditLog {
  id            String   @id @default(uuid())
  merchantId    String
  merchant      Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  correlationId String
  action        String
  details       String   @db.Text
  entityType    String   // e.g. "ORDER", "RULE", "INTEGRATION"
  entityId      String
  version       Int      @default(1)
  performedBy   String   // e.g. user ID or "SYSTEM"
  source        String   // e.g. "WORKFLOW_ENGINE", "MANUAL_DECISION"
  createdAt     DateTime @default(now())

  @@index([merchantId])
  @@index([correlationId])
}

model WebhookReplay {
  id            String   @id @default(uuid())
  provider      String
  webhookId     String   @unique
  signature     String?
  processedAt   DateTime @default(now())
}

model Shipment {
  id              String   @id @default(uuid())
  orderId         String   @unique
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courier         String
  trackingId      String?
  labelUrl        String?
  status          String   // PENDING, DISPATCHED, IN_TRANSIT, DELIVERED, RETURNED, FAILED
  trackingUpdates Json?    // JSON array of updates
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
