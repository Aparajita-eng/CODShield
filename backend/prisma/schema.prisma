datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  companyName  String?
  phone        String?
  merchantId   String?
  merchant     Merchant? @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  role         String    @default("Owner")
  createdAt    DateTime  @default(now())

  @@index([merchantId])
}

model Merchant {
  id         String   @id @default(uuid())
  name       String
  apiKeyHash String   @unique
  apiKeyMask String
  tier       String   // Starter, Growth, Enterprise
  claimRatio Float    @default(0.0)
  orders     Order[]
  users      User[]
  createdAt  DateTime @default(now())
}

model Order {
  id               String   @id @default(uuid())
  merchantId       String
  merchant         Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  phone            String
  pincode          String
  value            Float
  riskScore        Int
  protectionStatus String   // Protected, Held, Failed
  fulfillmentStatus String @default("Pending") // Pending, Verified, Shipped, Delivered, RTO, Cancelled
  fraudFlagged     Boolean  @default(false)
  statusReason     String
  createdAt        DateTime @default(now())
  claims           Claim[]
}

model PincodeRisk {
  pincode    String @id
  riskWeight Float  // 0.0 to 1.0
}

model Blacklist {
  phone        String   @id
  refusalCount Int
  reason       String
  createdAt    DateTime @default(now())
}

model Claim {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  proofUrl  String
  status    String   // Pending, Approved, Rejected
  step      Int      // 1: Upload, 2: Courier, 3: AI Check, 4: Payout
  notes     String?
  createdAt DateTime @default(now())
}

model VerifiedPhone {
  phone     String   @id
  expiresAt DateTime
}

model OtpAttempt {
  phone          String   @id
  attempts       Int      @default(0)
  firstAttemptAt DateTime @default(now())
}

model PasswordResetToken {
  tokenHash String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model DemoBooking {
  id            String        @id @default(uuid())
  name          String
  email         String
  company       String
  phone         String
  date          String        // YYYY-MM-DD
  timeSlot      String
  message       String?       @db.Text
  status        BookingStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

